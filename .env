# ═══════════════════════════════════════════════════════════════════════════════
# 财务智能体 - 环境配置
# ═══════════════════════════════════════════════════════════════════════════════

# ── 阿里云 DashScope API ─────────────────────────────────────────────────
DASHSCOPE_API_KEY=sk-a01e8524f1e546109be05291fcb67984
DASHSCOPE_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# ── 模型配置 ─────────────────────────────────────────────────────────────
LLM_MODEL=qwen-turbo

# ── Agent 配置 ───────────────────────────────────────────────────────────
MAX_LOOP=15
MAX_REACT_TURNS=20

# ── Checkpoint 持久化 ────────────────────────────────────────────────────
# memory: 服务重启后会话丢失，适合开发调试
# sqlite: 持久化到 SQLite 文件，服务重启后恢复（推荐开发环境）
# postgres: 持久化到 PostgreSQL，适合生产环境多实例部署
CHECKPOINT_PERSISTENCE=sqlite
SQLITE_DB_PATH=checkpoints.db
# POSTGRES_URL=postgresql://user:password@localhost:5432/langgraph

# ── 服务器配置 ────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=5001
SESSION_TTL_HOURS=168

# ── 人工审批配置 ─────────────────────────────────────────────────────────
HUMAN_APPROVAL_ENABLED=false
HUMAN_APPROVAL_FOR_VOUCHERS=false
HUMAN_APPROVAL_TIMEOUT=3600

# ── RAG 知识增强配置 ─────────────────────────────────────────────────────
RAG_ENABLED=false
KNOWLEDGE_DIR=agent/knowledge/chunks
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=agent/knowledge/chroma_db
RAG_TOP_K=5
RERANK_ENABLED=false
RAG_EMBEDDING_MODEL=text-embedding-v3
